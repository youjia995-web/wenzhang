# 极简版环境变量 — 没有任何第三方支付
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL（本地：docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/paid_articles?schema=public

# 作者后台：单密码登录（没有多用户）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=你的强密码_至少8位
ADMIN_DISPLAY_NAME=你的笔名

# 32+ 字符随机串：openssl rand -hex 32
ADMIN_JWT_SECRET=replace_with_64_hex_chars
READER_TOKEN_SECRET=replace_with_64_hex_chars

# 站点公开 URL（部署到 Zeabur 后改成你的域名）
PUBLIC_BASE_URL=http://localhost:3000

CORS_ORIGIN=*
