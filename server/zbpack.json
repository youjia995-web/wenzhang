# Zeabur 部署配置 (TOML 格式)
# https://zeabur.com/docs/marketplace/format
# 配合 Root Directory = server 使用，可一键部署

[build]
command = "npm install && npm run build"

[start]
# 先跑 prisma migrate deploy（幂等的，生产用 deploy 不是 dev），再启动 Node 服务
# DATABASE_URL 默认为 file:/data/prod.db（见 [volume] 段），SQLite 文件落在持久卷里
command = "npx prisma migrate deploy && npm start"

# 健康检查 — Zeabur 用这个端点判断服务是否存活
[healthcheck]
path = "/health"
port = 3000

# 暴露 HTTP 端口（Zeabur 自动生成 https://xxx.zeabur.app 域名）
[[ports]]
port = 3000
type = "HTTP"

# 持久卷 — SQLite 文件存这里，容器重启/重新部署都不会丢数据
# 也可在 Zeabur 控制台手动 Add Volume（Mount Path=/data）
[[volume]]
name = "data"
mountPath = "/data"